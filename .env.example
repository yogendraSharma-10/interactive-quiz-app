# --- Core Quiz Application Configuration ---

# Base URL for the Quiz API.
# This API provides quiz questions, categories, and potentially user scores.
# If using a local mock server or a dedicated backend, specify its URL here.
# Example: https://api.quizapp.com/v1
REACT_APP_QUIZ_API_BASE_URL=http://localhost:5000/api/quiz

# API Key for authenticating requests to the Quiz API (if required).
# Keep this secure and do not commit sensitive keys directly to version control.
# REACT_APP_QUIZ_API_KEY=your_quiz_api_key_here

# Default category ID or slug to load quizzes from if no specific category is selected by the user.
# This could be a numeric ID (e.g., "9" for General Knowledge in Open Trivia DB)
# or a string slug (e.g., "general-knowledge").
REACT_APP_DEFAULT_QUIZ_CATEGORY=general-knowledge

# Default difficulty level for quizzes.
# Options typically include: "easy", "medium", "hard".
REACT_APP_DEFAULT_QUIZ_DIFFICULTY=medium

# Default number of questions to fetch per quiz session.
REACT_APP_DEFAULT_QUESTION_COUNT=10

# --- Cross-Project Microservice Integration ---

# Base URL for the AI-Powered Content Summarizer service.
# This could be used to generate summaries of quiz topics, provide additional learning resources,
# or analyze quiz performance data.
# Example: https://api.summarizer.yourplatform.com/v1
# REACT_APP_AI_SUMMARIZER_API_URL=http://localhost:6000/api/summarize

# Base URL for the Full-Stack Blog Platform.
# The quiz app might link to related blog posts for further reading on quiz categories or topics.
# Example: https://blog.yourplatform.com
# REACT_APP_BLOG_PLATFORM_URL=http://localhost:7000

# Base URL for a central API Gateway, if all microservices are accessed through one unified endpoint.
# This might override specific service URLs if the gateway handles routing based on paths.
# Example: https://api.yourplatform.com/v1
# REACT_APP_API_GATEWAY_URL=http://localhost:8000/api

# --- Application Specific Settings ---

# The name of the application, used for display purposes in the UI (e.g., header, title).
REACT_APP_APP_NAME="Interactive Quiz App"

# Environment setting (e.g., 'development', 'production', 'test').
# Useful for conditional logic within the application, such as logging or feature flags.
REACT_APP_ENVIRONMENT=development